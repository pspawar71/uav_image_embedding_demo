{
 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# ResNet‑18 Feature Maps and Image Embedding (Complete Explanation)\n",
    "\n",
    "This notebook explains **how a ResNet‑18 model processes an image** using 3×3 convolutions,\n",
    "what the **feature maps represent at each layer**, how the **final 512‑D embedding** is formed,\n",
    "and how to **export that embedding as a CSV file**."
   ]
  },

  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Imports"
   ]
  },

  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import torch\n",
    "import torch.nn as nn\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "import math\n",
    "from torchvision import models, transforms\n",
    "from PIL import Image\n",
    "from pathlib import Path\n",
    "from matplotlib.patches import FancyArrowPatch"
   ]
  },

  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Device"
   ]
  },

  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "device = torch.device('cpu')\n",
    "print('Using device:', device)"
   ]
  },

  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Load ResNet‑18 in embedding mode\n",
    "\n",
    "The classification head is removed so the network outputs **512 numerical features** instead of class scores."
   ]
  },

  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "model = models.resnet18(weights=models.ResNet18_Weights.IMAGENET1K_V1)\n",
    "model.fc = nn.Identity()\n",
    "model.eval()"
   ]
  },

  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Capture feature maps using hooks"
   ]
  },

  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "feature_maps = {}\n",
    "\n",
    "def hook_fn(name):\n",
    "    def hook(module, inp, out):\n",
    "        feature_maps[name] = out.detach().cpu()\n",
    "    return hook\n",
    "\n",
    "model.conv1.register_forward_hook(hook_fn('conv1'))\n",
    "model.layer1.register_forward_hook(hook_fn('layer1'))\n",
    "model.layer2.register_forward_hook(hook_fn('layer2'))\n",
    "model.layer3.register_forward_hook(hook_fn('layer3'))\n",
    "model.layer4.register_forward_hook(hook_fn('layer4'))"
   ]
  },

  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Image preprocessing (ImageNet standard)"
   ]
  },

  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "transform = transforms.Compose([\n",
    "    transforms.Resize(256),\n",
    "    transforms.CenterCrop(256),\n",
    "    transforms.ToTensor(),\n",
    "    transforms.Normalize([0.485,0.456,0.406],[0.229,0.224,0.225])\n",
    "])"
   ]
  },

  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Load input image"
   ]
  },

  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "img_path = Path('data') / '25DIV3FAY_1002.jpg'\n",
    "assert img_path.exists(), 'Image not found in data folder'\n",
    "\n",
    "img = Image.open(img_path).convert('RGB')\n",
    "x = transform(img).unsqueeze(0)\n",
    "\n",
    "plt.imshow(img)\n",
    "plt.axis('off')\n",
    "plt.title('Input Image')\n",
    "plt.show()"
   ]
  },

  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Forward pass"
   ]
  },

  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "with torch.no_grad():\n",
    "    embedding = model(x).squeeze().numpy()\n",
    "\n",
    "print('Embedding shape:', embedding.shape)"
   ]
  },

  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Feature‑map visualization utility"
   ]
  },

  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def visualize_feature_maps(fmap, title, max_channels=16):\n",
    "    fmap = fmap.squeeze(0)\n",
    "    n = min(fmap.shape[0], max_channels)\n",
    "    grid = math.ceil(math.sqrt(n))\n",
    "    plt.figure(figsize=(8,8))\n",
    "    for i in range(n):\n",
    "        fm = fmap[i]\n",
    "        fm = (fm - fm.min()) / (fm.max() - fm.min() + 1e-6)\n",
    "        plt.subplot(grid, grid, i+1)\n",
    "        plt.imshow(fm, cmap='viridis')\n",
    "        plt.axis('off')\n",
    "    plt.suptitle(title)\n",
    "    plt.tight_layout()\n",
    "    plt.show()"
   ]
  },

  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### conv1 — edges and color gradients"
   ]
  },

  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "visualize_feature_maps(feature_maps['conv1'], 'conv1: edges and colors')"
   ]
  },

  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### layer1 — low‑level textures"
   ]
  },

  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "visualize_feature_maps(feature_maps['layer1'], 'layer1: textures')"
   ]
  },

  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### layer2 — canopy patterns"
   ]
  },

  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "visualize_feature_maps(feature_maps['layer2'], 'layer2: canopy patterns')"
   ]
  },

  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### layer3 — spatial structure"
   ]
  },

  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "visualize_feature_maps(feature_maps['layer3'], 'layer3: structure')"
   ]
  },

  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### layer4 — high‑level semantics"
   ]
  },

  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "visualize_feature_maps(feature_maps['layer4'], 'layer4: semantics')"
   ]
  },

  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Full ResNet‑18 architecture diagram (before CSV export)"
   ]
  },

  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "layer_order = [\n",
    "    'conv1',\n",
    "    'layer1.0.conv1','layer1.0.conv2','layer1.1.conv1','layer1.1.conv2',\n",
    "    'layer2.0.conv1','layer2.0.conv2','layer2.1.conv1','layer2.1.conv2',\n",
    "    'layer3.0.conv1','layer3.0.conv2','layer3.1.conv1','layer3.1.conv2',\n",
    "    'layer4.0.conv1','layer4.0.conv2','layer4.1.conv1','layer4.1.conv2'\n",
    "]\n",
    "\n",
    "def draw_arrow(ax, x1, y1, x2, y2):\n",
    "    ax.add_patch(FancyArrowPatch((x1,y1),(x2,y2),arrowstyle='->',linewidth=1))\n",
    "\n",
    "def representative_maps(fmap, n=3):\n",
    "    fmap = fmap.squeeze(0)\n",
    "    idxs = np.linspace(0, fmap.shape[0]-1, n, dtype=int)\n",
    "    return [(fmap[i]-fmap[i].min())/(fmap[i].max()-fmap[i].min()+1e-6) for i in idxs]\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(22,7))\n",
    "ax.axis('off')\n",
    "ax.set_xlim(0,30)\n",
    "ax.set_ylim(0,8)\n",
    "\n",
    "ax.imshow(img.resize((128,128)), extent=(0.5,2.5,4,6))\n",
    "ax.text(1.5,3.5,'Input Image',ha='center')\n",
    "\n",
    "px,py,x = 2.5,5.0,4.0\n",
    "for lname in layer_order:\n",
    "    fmap = feature_maps[lname.split('.')[0]]\n",
    "    reps = representative_maps(fmap)\n",
    "    for i,fm in enumerate(reps):\n",
    "        ax.imshow(fm, extent=(x,x+1,1.5+i*1.1,2.5+i*1.1), cmap='viridis')\n",
    "    ax.text(x+0.5,1.1,lname,ha='center',fontsize=7)\n",
    "    draw_arrow(ax,px,py,x,3.5)\n",
    "    px,py = x+1,3.5\n",
    "    x+=1.4\n",
    "\n",
    "plt.show()"
   ]
  },

  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Embedding DataFrame"
   ]
  },

  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "df_embedding = pd.DataFrame([embedding], columns=[f'emb_{i}' for i in range(512)])\n",
    "df_embedding.insert(0,'image_id',img_path.name)\n",
    "df_embedding"
   ]
  },

  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Save embedding to CSV"
   ]
  },

  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "df_embedding.to_csv('image_embedding.csv', index=False)\n",
    "print('image_embedding.csv saved')"
   ]
  }
 ],
