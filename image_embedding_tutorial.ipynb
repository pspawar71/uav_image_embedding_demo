{
 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# ResNet‑18 Feature Maps and Image Embedding (Explained)\n",
    "\n",
    "This notebook demonstrates how **ResNet‑18** transforms an image into a **512‑D embedding**,\n",
    "while explaining what each layer learns and visualizing representative feature maps."
   ]
  },

  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Imports"
   ]
  },

  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import torch\n",
    "import torch.nn as nn\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "import math\n",
    "from torchvision import models, transforms\n",
    "from PIL import Image\n",
    "from pathlib import Path\n",
    "from matplotlib.patches import FancyArrowPatch\n"
   ]
  },

  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Device"
   ]
  },

  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "device = torch.device(\"cpu\")\n",
    "print(\"Using device:\", device)"
   ]
  },

  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Load ResNet‑18 in embedding mode"
   ]
  },

  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "model = models.resnet18(weights=models.ResNet18_Weights.IMAGENET1K_V1)\n",
    "model.fc = nn.Identity()\n",
    "model.eval()"
   ]
  },

  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Store feature maps using hooks"
   ]
  },

  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "feature_maps = {}\n",
    "\n",
    "def hook_fn(name):\n",
    "    def hook(module, input, output):\n",
    "        feature_maps[name] = output.detach().cpu()\n",
    "    return hook\n",
    "\n",
    "model.conv1.register_forward_hook(hook_fn(\"conv1\"))\n",
    "model.layer1.register_forward_hook(hook_fn(\"layer1\"))\n",
    "model.layer2.register_forward_hook(hook_fn(\"layer2\"))\n",
    "model.layer3.register_forward_hook(hook_fn(\"layer3\"))\n",
    "model.layer4.register_forward_hook(hook_fn(\"layer4\"))"
   ]
  },

  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Image preprocessing"
   ]
  },

  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "transform = transforms.Compose([\n",
    "    transforms.Resize(256),\n",
    "    transforms.CenterCrop(256),\n",
    "    transforms.ToTensor(),\n",
    "    transforms.Normalize([0.485,0.456,0.406],[0.229,0.224,0.225])\n",
    "])"
   ]
  },

  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Load input image"
   ]
  },

  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "img_path = Path(\"data\") / \"25DIV3FAY_1002.jpg\"\n",
    "assert img_path.exists(), \"Image not found in data folder\"\n",
    "\n",
    "img = Image.open(img_path).convert(\"RGB\")\n",
    "x = transform(img).unsqueeze(0)\n",
    "\n",
    "plt.figure(figsize=(4,4))\n",
    "plt.imshow(img)\n",
    "plt.axis(\"off\")\n",
    "plt.title(\"Input Image\")\n",
    "plt.show()"
   ]
  },

  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Forward pass"
   ]
  },

  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "with torch.no_grad():\n",
    "    embedding = model(x).squeeze().numpy()\n",
    "\n",
    "print(\"Embedding shape:\", embedding.shape)"
   ]
  },

  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Full ResNet‑18 architecture diagram with representative feature maps"
   ]
  },

  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "layer_order = [\n",
    "    \"conv1\",\n",
    "    \"layer1.0.conv1\", \"layer1.0.conv2\",\n",
    "    \"layer1.1.conv1\", \"layer1.1.conv2\",\n",
    "    \"layer2.0.conv1\", \"layer2.0.conv2\",\n",
    "    \"layer2.1.conv1\", \"layer2.1.conv2\",\n",
    "    \"layer3.0.conv1\", \"layer3.0.conv2\",\n",
    "    \"layer3.1.conv1\", \"layer3.1.conv2\",\n",
    "    \"layer4.0.conv1\", \"layer4.0.conv2\",\n",
    "    \"layer4.1.conv1\", \"layer4.1.conv2\",\n",
    "]\n",
    "\n",
    "def draw_arrow(ax, x1, y1, x2, y2):\n",
    "    ax.add_patch(FancyArrowPatch((x1,y1),(x2,y2),arrowstyle=\"->\",linewidth=1))\n",
    "\n",
    "def representative_maps(fmap, n=3):\n",
    "    fmap = fmap.squeeze(0)\n",
    "    C = fmap.shape[0]\n",
    "    idxs = np.linspace(0, C-1, n, dtype=int)\n",
    "    maps = []\n",
    "    for i in idxs:\n",
    "        fm = fmap[i]\n",
    "        fm = (fm - fm.min()) / (fm.max() - fm.min() + 1e-6)\n",
    "        maps.append(fm.numpy())\n",
    "    return maps\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(22,7))\n",
    "ax.axis('off')\n",
    "ax.set_xlim(0, 30)\n",
    "ax.set_ylim(0, 8)\n",
    "\n",
    "ax.imshow(img.resize((128,128)), extent=(0.5,2.5,4,6))\n",
    "ax.text(1.5,3.5,\"Input Image\\n3×256×256\",ha='center')\n",
    "\n",
    "prev_x, prev_y = 2.5, 5.0\n",
    "x = 4.0\n",
    "\n",
    "for lname in layer_order:\n",
    "    base = lname.split('.')[0]\n",
    "    fmap = feature_maps[base]\n",
    "    C,H,W = fmap.shape[1:]\n",
    "    reps = representative_maps(fmap)\n",
    "    for i,fm in enumerate(reps):\n",
    "        ax.imshow(fm, extent=(x,x+1,1.5+i*1.1,2.5+i*1.1), cmap='viridis')\n",
    "    ax.text(x+0.5,1.1,f\"{lname}\\n{C}×{H}×{W}\",ha='center',fontsize=7)\n",
    "    draw_arrow(ax, prev_x, prev_y, x, 3.5)\n",
    "    prev_x, prev_y = x+1, 3.5\n",
    "    x += 1.4\n",
    "\n",
    "draw_arrow(ax, prev_x, prev_y, x, prev_y)\n",
    "ax.add_patch(plt.Rectangle((x,3),1.6,1,fc='#dddddd',ec='black'))\n",
    "ax.text(x+0.8,2.4,\"Global Avg Pool\\n512\",ha='center')\n",
    "\n",
    "draw_arrow(ax, x+1.6, prev_y, x+3.6, prev_y)\n",
    "ax.add_patch(plt.Rectangle((x+3.6,3),3,1,fc='#cccccc',ec='black'))\n",
    "ax.text(x+5.1,2.4,\"Image Embedding\\n512‑D\",ha='center')\n",
    "\n",
    "plt.suptitle(\"ResNet‑18 Image Embedding Pipeline\",fontsize=14)\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },

  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Embedding DataFrame and CSV export"
   ]
  },

  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "df_embedding = pd.DataFrame([embedding], columns=[f'emb_{i}' for i in range(512)])\n",
    "df_embedding.insert(0, 'image_id', img_path.name)\n",
    "df_embedding"
   ]
  },

  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "df_embedding.to_csv('image_embedding.csv', index=False)\n",
    "print('Embedding saved to image_embedding.csv')"
   ]
  }
 ],
