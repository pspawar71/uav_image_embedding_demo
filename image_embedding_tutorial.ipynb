"""
Image Embedding Tutorial with ResNet-18 (PyTorch)

This script demonstrates:
- Layer-wise feature extraction using ResNet-18
- Global Average Pooling
- Construction of a 512-D image embedding
- Visualization of representative feature maps
- Saving embeddings as a Pandas DataFrame

CPU-only and Binder-compatible.
"""

# =========================================================
# 1. Imports
# =========================================================
import torch
import torch.nn as nn
import numpy as np
import matplotlib.pyplot as plt
import pandas as pd
from torchvision import models, transforms
from PIL import Image


# =========================================================
# 2. Device (CPU only)
# =========================================================
device = torch.device("cpu")
print("Using device:", device)


# =========================================================
# 3. Load ResNet-18 in EMBEDDING mode
# =========================================================
model = models.resnet18(
    weights=models.ResNet18_Weights.IMAGENET1K_V1
)

# Remove classifier → keep 512-D embedding
model.fc = nn.Identity()
model.eval().to(device)

print("ResNet-18 loaded in embedding mode")


# =========================================================
# 4. Register hooks for feature maps
# =========================================================
feature_maps = {}

def save_hook(name):
    def hook(module, input, output):
        feature_maps[name] = output.detach().cpu()
    return hook

# Register hooks for main stages
model.conv1.register_forward_hook(save_hook("conv1"))
model.layer1.register_forward_hook(save_hook("layer1"))
model.layer2.register_forward_hook(save_hook("layer2"))
model.layer3.register_forward_hook(save_hook("layer3"))
model.layer4.register_forward_hook(save_hook("layer4"))

print("Feature-map hooks registered")


# =========================================================
# 5. Image preprocessing (ImageNet)
# =========================================================
transform = transforms.Compose([
    transforms.Resize(256),
    transforms.CenterCrop(256),
    transforms.ToTensor(),
    transforms.Normalize(
        mean=[0.485, 0.456, 0.406],
        std=[0.229, 0.224, 0.225],
    ),
])


# =========================================================
# 6. Load image
# =========================================================
image_path = "data/25DIV3FAY_1002.jpg"  # change if needed
img = Image.open(image_path).convert("RGB")

plt.figure(figsize=(4, 4))
plt.imshow(img)
plt.title("Input Image")
plt.axis("off")
plt.show()

x = transform(img).unsqueeze(0).to(device)


# =========================================================
# 7. Forward pass & embedding extraction
# =========================================================
with torch.no_grad():
    embedding = model(x).squeeze().numpy()

print("Embedding shape:", embedding.shape)  # (512,)


# =========================================================
# 8. Representative feature maps
# =========================================================
def representative_maps(fmap, n=3):
    """
    Select n representative channels from a feature map tensor.
    fmap: [1, C, H, W]
    """
    fmap = fmap.squeeze(0)
    C = fmap.shape[0]
    idxs = np.linspace(0, C - 1, n, dtype=int)

    maps = []
    for i in idxs:
        fm = fmap[i]
        fm = (fm - fm.min()) / (fm.max() - fm.min() + 1e-6)
        maps.append(fm.numpy())
    return maps


# =========================================================
# 9. Layer-wise tutorial visualization (KEY FIGURE)
# =========================================================
fig, ax = plt.subplots(figsize=(20, 6))
ax.axis("off")

x_pos = 2
y_base = 1

# Input image
ax.imshow(img.resize((128, 128)), extent=(0, 1, 2, 3))
ax.text(0.5, 1.6, "Input\n256×256×3", ha="center")

layer_order = ["conv1", "layer1", "layer2", "layer3", "layer4"]

for name in layer_order:
    fmap = feature_maps[name]
    reps = representative_maps(fmap, n=3)
    C, H, W = fmap.shape[1:]

    for i, fm in enumerate(reps):
        ax.imshow(
            fm,
            extent=(x_pos, x_pos + 0.8,
                    y_base + i * 0.9, y_base + i * 0.9 + 0.8),
            cmap="viridis"
        )

    ax.text(
        x_pos + 0.4,
        y_base - 0.3,
        f"{name}\n{C}×{H}×{W}",
        ha="center",
        fontsize=8
    )

    x_pos += 1.1

# Embedding visualization
ax.bar(
    np.linspace(x_pos, x_pos + 2, 512),
    embedding,
    width=0.003,
    color="black"
)
ax.text(x_pos + 1, 1.5, "Embedding\n512‑D", ha="center")

plt.title("ResNet‑18: Layer‑wise Feature Maps and Image Embedding (True Activations)")
plt.tight_layout()
plt.show()


# =========================================================
# 10. Embedding DataFrame
# =========================================================
df_embedding = pd.DataFrame(
    [embedding],
    columns=[f"emb_{i}" for i in range(len(embedding))]
)

df_embedding.insert(0, "image_id", image_path)

print(df_embedding.head())


# =========================================================
# 11. Save embedding to CSV
# =========================================================
df_embedding.to_csv("image_embedding.csv", index=False)
print("✅ Embedding saved to image_embedding.csv")


# =========================================================
# 12. Notes
# =========================================================
print("""
Notes:
- Global Average Pooling converts 512 × 8 × 8 → 512
- Each embedding dimension represents a learned visual concept
- Script is deterministic and CPU-only
- Suitable for Binder, GitHub, and teaching
""")
